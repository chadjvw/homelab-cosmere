{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Skip date based images",
      matchDatasources: ["docker"],
      allowedVersions: "!/^\\d{4}.*$/",
    },
    {
      description: "Avoid old lidarr images",
      matchDatasources: ["docker"],
      matchPackageNames: "ghcr.io/linuxserver/lidarr",
      allowedVersions: "<=8.0",
    },
    {
      description: "Avoid old qbittorrent images",
      matchDatasources: ["docker"],
      matchPackageNames: "ghcr.io/linuxserver/qbittorrent",
      allowedVersions: "<=14.0",
    },
    {
      description: "Auto-merge GitHub Actions minor/patch updates",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "digest"],
      ignoreTests: true,
    },
    {
      description: "Separate minor and patch for Talos/Kubernetes to enforce sequential upgrades",
      matchPackageNames: [
        "ghcr.io/siderolabs/installer",
        "ghcr.io/siderolabs/kubelet",
      ],
      separateMinorPatch: true,
    },
    {
      description: "Auto-merge Talos/Kubernetes patch updates",
      matchPackageNames: [
        "ghcr.io/siderolabs/installer",
        "ghcr.io/siderolabs/kubelet",
      ],
      matchUpdateTypes: ["patch"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
    },
    {
      description: "Auto-merge infra and apps Helm chart patch updates",
      matchFileNames: ["infra/**", "apps/**"],
      matchManagers: ["flux"],
      matchUpdateTypes: ["patch"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
    },
  ],
}
